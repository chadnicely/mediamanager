# Copy to .env and fill in. (Never commit the real .env.)

# MongoDB connection string.
#   Local:  mongodb://127.0.0.1:27017/jotter
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/jotter
MONGODB_URI=mongodb://127.0.0.1:27017/jotter

# Secret used to sign login tokens — set to a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on.
PORT=4500
